---
import IndexLayout from '@/layouts/IndexLayout.astro'

const pageTitle = '近况'
const pageDescription = '我现在在做什么'
---

<IndexLayout title={pageTitle} description={pageDescription}>
  <div class="now-page">
    <h1>近况</h1>
    <p class="lede">
      这是一个 <a href="https://nownownow.com/about" target="_blank" rel="noopener noreferrer"
        >now</a
      > 页面 —— 记录我目前的关注点。
    </p>

    <section class="now-section">
      <h2>生活</h2>
      <p>中国，广东，深圳</p>
    </section>

    <section class="now-section">
      <h2>工作</h2>
      <p>
        目前就职于 <a href="https://www.isumsoft.com/" target="_blank" rel="noopener noreferrer"
          >iSumsoft</a
        >。
      </p>
    </section>

    <section class="now-section">
      <h2>学习</h2>
      <ul class="learning-list">
        <li>
          <a
            href="https://docs.astro.build/en/tutorial/0-introduction/"
            target="_blank"
            rel="noopener noreferrer">Astro</a
          >
        </li>
        <li>SEO</li>
        <li>西班牙语</li>
      </ul>
    </section>

    <section class="now-section">
      <h2>娱乐</h2>
      <div class="game-badges">
        <a
          href="https://steamcommunity.com/profiles/76561199002529456"
          target="_blank"
          rel="noopener noreferrer"
          class="game-badge"
        >
          <img
            alt="Steam"
            src="https://img.shields.io/badge/Steam-171a21?style=flat-square&logo=steam&logoColor=white"
          />
        </a>
        <a
          href="https://www.counter-strike.net/cs2"
          target="_blank"
          rel="noopener noreferrer"
          class="game-badge"
        >
          <img
            alt="CS2"
            src="https://img.shields.io/badge/CS2-FF6B00?style=flat-square&logo=counter-strike&logoColor=white"
          />
        </a>
        <a
          href="https://valorant.qq.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="game-badge"
        >
          <img
            alt="Valorant"
            src="https://img.shields.io/badge/Valorant-FA4454?style=flat-square&logo=valorant&logoColor=white"
          />
        </a>
        <a href="https://lol.qq.com/" target="_blank" rel="noopener noreferrer" class="game-badge">
          <img
            alt="LOL"
            src="https://img.shields.io/badge/LOL-0BC6E3?style=flat-square&logo=league-of-legends&logoColor=white"
          />
        </a>
        <a href="https://aimlabs.com/" target="_blank" rel="noopener noreferrer" class="game-badge">
          <img
            alt="AimLab"
            src="https://img.shields.io/badge/AimLab-6C5CE7?style=flat-square&logo=target&logoColor=white"
          />
        </a>
      </div>
    </section>
  </div>
</IndexLayout>

<style>
  .now-page {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .now-page h1 {
    margin: 0;
    font-size: 1.75rem;
    font-weight: 600;
  }

  .lede {
    margin: 0 0 1rem 0;
    color: var(--text-secondary);
    font-size: 0.95rem;
  }

  .lede a {
    color: var(--text-primary);
    text-decoration: none;
    padding: 0 0.12em;
    transition: background-color 0.15s ease-out;
  }

  .lede a:hover {
    background-color: var(--selection);
  }

  .now-section {
    padding: 1rem 0;
    border-top: 1px solid var(--border);
  }

  .now-section h2 {
    margin: 0 0 0.5rem 0;
    font-size: 1.1rem;
    font-weight: 600;
  }

  .now-section p {
    margin: 0;
    line-height: 1.6;
  }

  .now-section a {
    color: var(--text-primary);
    text-decoration: none;
    padding: 0 0.12em;
    transition: background-color 0.15s ease-out;
  }

  .now-section a:hover {
    background-color: var(--selection);
  }

  .learning-list {
    margin: 0;
    padding-left: 1.25rem;
    line-height: 1.8;
  }

  .game-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .game-badge {
    border: none;
    transition: opacity 0.2s ease;
  }

  .game-badge:hover {
    opacity: 0.7;
  }

  .game-badge img {
    display: block;
    height: 22px;
  }
</style>
